  "description": "Coup d'Envoi TV est créé par Adrien, passionné de football, pour centraliser le programme TV foot en France.",
  "author": {
    "@type": "Person",
    "name": "Adrien",
    "email": "coupdenvoi@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "13 Allées Léon Gambetta",
      "addressLocality": "Clichy",
      "postalCode": "92110",
      "addressCountry": "FR"
    }
  }
}
</script>
