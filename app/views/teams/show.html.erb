{
  "@context": "https://schema.org",
  "@type": "SportsTeam",
  "name": "<%= @team_name %>",
  "sport": "Football",
  "logo": "<%= @team_logo %>",
  "url": "<%= request.original_url %>"<% if @stats&.dig("league", "name") %>,
  "memberOf": {
    "@type": "SportsOrganization",
    "name": "<%= @stats.dig("league", "name") %>"
  }<% end %>
}
</script>

