<%#
  Partial : carte affilié Canal+
  Activation : heroku config:set CANAL_PLUS_AFFILIATE_URL="https://..."
  Locals :
    - variant      (:standard | :compact)  default: :standard
    - page_context (string GA4 : 'match', 'channel', 'competition', 'blog') default: 'site'
    - cta_index    (0..2 pour A/B CTA) default: 0
    - subtitle     (string optionnel pour surcharger le texte sous le titre)
%>
<% canal_url = local_assigns.fetch(:url, "https://action.metaffiliation.com/trk.php?mclic=P4F53158AAFD1561") %>

<% variant      = local_assigns.fetch(:variant, :standard) %>
<% page_context = local_assigns.fetch(:page_context, "site") %>
<% cta_index    = local_assigns.fetch(:cta_index, 0) %>
<% ctas = ["S'abonner à Canal+", "Voir ce match sur Canal+", "Essayer Canal+ gratuitement"] %>
<% cta_text = local_assigns[:cta_label].presence || ctas[cta_index % 3] %>
<% ga_push = "dataLayer.push({event:'affiliate_click',affiliate_partner:'canal_plus',affiliate_page:'#{page_context}',affiliate_cta:#{cta_index % 3}})" %>

<% if variant == :compact %>
  <%= link_to canal_url, target: "_blank", rel: "nofollow sponsored noopener",
      style: "color: #3b82f6; font-weight: 600; text-decoration: none;",
      onclick: ga_push do %>
    <%= cta_text %> →
  <% end %>

<% else %>
  <% card_subtitle = local_assigns[:subtitle].presence ||
    "Champions League, Europa League, Conference League et Ligue 1 - regardez le foot en direct sur Canal+." %>

  <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 10px; padding: 16px 18px; margin: 22px 0;">
    <div style="margin-bottom: 10px;">
      <span style="font-size: 13px; font-weight: 900; letter-spacing: 0.04em; color: #fff; background: #dc314e; border-radius: 4px; padding: 3px 10px; font-family: 'DM Sans', sans-serif;">CANAL+</span>
    </div>
    <p style="margin: 0 0 14px; font-size: 13px; color: var(--color-muted); line-height: 1.55; font-family: 'DM Sans', sans-serif;"><%= card_subtitle %></p>
    <%= link_to canal_url, target: "_blank", rel: "nofollow sponsored noopener",
        onclick: ga_push,
        onmouseover: "this.style.opacity='0.82'",
        onmouseout: "this.style.opacity='1'",
        style: "display: block; width: 100%; background: #dc314e; color: white; font-size: 13px; font-weight: 700; padding: 11px 0; border-radius: 8px; text-decoration: none; text-align: center; font-family: 'DM Sans', sans-serif; box-sizing: border-box; transition: opacity 0.15s;" do %>
      <%= cta_text %> →
    <% end %>
    <p style="margin: 8px 0 0; font-size: 9px; color: var(--color-muted); text-align: center; font-family: 'DM Sans', sans-serif; opacity: 0.6;">Lien affilié · commission perçue sur souscription</p>
  </div>
<% end %>
