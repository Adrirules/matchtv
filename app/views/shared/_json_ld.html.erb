<% content_for :json_ld do %>
<%
  home = team_display_name(match.home_team)
  away = team_display_name(match.away_team)

  description_aeo = if match.finished? && match.home_score.present?
    "Résultat : #{home} #{match.home_score}-#{match.away_score} #{away} - #{match.competition}"
  else
    "Sur quelle chaîne voir #{home} vs #{away} ? Le #{match.start_time.strftime('%d/%m')}#{match.tv_channels.present? ? ' sur ' + match.tv_channels : ''} pour la #{match.competition}."
  end
%>
<script type="application/ld+json">
  <%= {
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    "name": "#{home} - #{away}",
    "description": description_aeo,
    "startDate": match.start_time.iso8601,
    "endDate": (match.start_time + 115.minutes).iso8601,
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "image": [match.home_team_logo, match.away_team_logo].reject(&:blank?),
    "sport": "Football",
    "homeTeam": {
      "@type": "SportsTeam",
      "name": home,
      "logo": match.home_team_logo,
      "url": "https://www.coupdenvoi.tv/equipes/#{match.home_team&.parameterize}"
    },
    "awayTeam": {
      "@type": "SportsTeam",
      "name": away,
      "logo": match.away_team_logo,
      "url": "https://www.coupdenvoi.tv/equipes/#{match.away_team&.parameterize}"
    },
    "url": "https://www.coupdenvoi.tv/matches/#{match.matchup&.slug || match.id}",
    "location": {
      "@type": "Place",
      "name": match.venue_name.presence || match.competition || "Stade",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": match.venue_city.presence || "",
        "addressCountry": FootballApiService::COMPETITIONS_META.find { |c| c[:name] == match.competition }&.dig(:country) || "France"
      }
    },
    "performer": [
      { "@type": "SportsTeam", "name": home },
      { "@type": "SportsTeam", "name": away }
    ],
    "organizer": {
      "@type": "Organization",
      "name": match.competition || "Fédération de Football",
      "url": "https://www.coupdenvoi.tv/competitions/#{match.competition&.parameterize}"
    },
    "offers": {
      "@type": "Offer",
      "name": "Accès gratuit",
      "url": "https://www.coupdenvoi.tv/matches/#{match.matchup&.slug || match.id}",
      "price": "0",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "validFrom": (match.created_at || Time.current).iso8601
    }
  }.to_json.html_safe %>
</script>
<%# BroadcastEvent — uniquement pour les matchs à venir/en direct avec une chaîne identifiable %>
<% if !match.finished? && match.tv_channels.present? %>
<%
  ch_main = match.tv_channels.split(',').first&.strip
  broadcast_url = if match.tv_channels.include?('DAZN')
    'https://www.dazn.com'
  elsif match.tv_channels.include?('Canal')
    'https://www.canalplus.com'
  elsif match.tv_channels.include?('beIN')
    'https://www.beinsports.com'
  elsif match.tv_channels.include?('RMC')
    'https://rmcsport.bfmtv.com'
  else
    "https://www.coupdenvoi.tv/chaines/#{ch_main&.parameterize}"
  end
%>
<script type="application/ld+json">
<%= {
  "@context": "https://schema.org",
  "@type": "BroadcastEvent",
  "name": "#{home} vs #{away} en direct",
  "isLiveBroadcast": true,
  "startDate": match.start_time.iso8601,
  "endDate": (match.start_time + 115.minutes).iso8601,
  "videoFormat": "HD",
  "broadcastDisplayName": ch_main,
  "broadcastOfEvent": {
    "@type": "SportsEvent",
    "name": "#{home} - #{away}",
    "startDate": match.start_time.iso8601,
    "url": "https://www.coupdenvoi.tv/matches/#{match.matchup&.slug || match.id}"
  },
  "publishedOn": {
    "@type": "BroadcastService",
    "name": ch_main,
    "url": broadcast_url,
    "broadcastAffiliateOf": {
      "@type": "Organization",
      "name": ch_main
    }
  }
}.to_json.html_safe %>
</script>
<% end %>
<% end %>
