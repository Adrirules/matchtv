<%# Partial FAQ accordion - usage: render 'shared/faq_accordion', items: [{q: "...", a: "..."}], schema: true %>
<%# schema: true → génère le JSON-LD FAQPage (ne mettre qu'une seule fois par page) %>

<section>
  <% items.each do |item| %>
    <details class="faq-item">
      <summary class="faq-question">
        <%= item[:q].html_safe %>
        <span class="faq-chevron">&#8964;</span>
      </summary>
      <div class="faq-answer">
        <p><%= item[:a].html_safe %></p>
      </div>
    </details>
  <% end %>
</section>

<% if local_assigns[:schema] %>
  <% content_for :json_ld do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": <%= items.map { |i| { "@type" => "Question", "name" => i[:q], "acceptedAnswer" => { "@type" => "Answer", "text" => i[:a] } } }.to_json.html_safe %>
  }
  </script>
  <% end %>
<% end %>
