<% priority = local_assigns.fetch(:priority, false) %>
<%= link_to match_path(match.slug || match.id), style: "text-decoration: none; color: inherit; display: block; margin-bottom: 8px;" do %>
<% cache [match, match.updated_at, priority, 'v2design2'] do %>
<div class="match-card<%= ' match-card--live' if match.live? %>">

  <%# Ligne 1 : Domicile — Score/Heure — Extérieur %>
  <div style="display:flex;align-items:center;margin-bottom:6px;">

    <%# Équipe domicile %>
    <div style="display:flex;align-items:center;gap:4px;flex:1;min-width:0;overflow:hidden;">
      <img src="<%= match.home_team_logo %>" alt="<%= team_display_name(match.home_team) %>" width="16" height="16"
           loading="<%= priority ? 'eager' : 'lazy' %>" fetchpriority="<%= priority ? 'high' : 'low' %>"
           style="width:16px;height:16px;object-fit:contain;flex-shrink:0;">
      <span style="font-size:13px;font-weight:600;color:var(--color-text);font-family:'DM Sans',sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0;"><%= team_display_name(match.home_team) %></span>
    </div>

    <%# Score / Heure %>
    <div style="flex-shrink:0;width:52px;text-align:center;font-family:'Barlow Condensed',sans-serif;">
      <% if match.live? %>
        <span style="font-weight:800;font-size:15px;color:var(--color-live);"><%= match.home_score %> - <%= match.away_score %></span>
      <% elsif match.has_score? %>
        <span style="font-weight:800;font-size:15px;color:var(--color-text);"><%= match.home_score %> - <%= match.away_score %></span>
      <% else %>
        <span style="font-weight:700;font-size:14px;color:var(--color-muted);"><%= match.start_time.strftime("%H:%M") %></span>
      <% end %>
    </div>

    <%# Équipe extérieure %>
    <div style="display:flex;align-items:center;gap:4px;flex:1;min-width:0;overflow:hidden;justify-content:flex-end;">
      <span style="font-size:13px;font-weight:600;color:var(--color-text);font-family:'DM Sans',sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0;text-align:right;"><%= team_display_name(match.away_team) %></span>
      <img src="<%= match.away_team_logo %>" alt="<%= team_display_name(match.away_team) %>" width="16" height="16"
           loading="<%= priority ? 'eager' : 'lazy' %>" fetchpriority="<%= priority ? 'high' : 'low' %>"
           style="width:16px;height:16px;object-fit:contain;flex-shrink:0;">
    </div>
  </div>

  <%# Ligne 2 : Live + Badge chaîne + Compétition %>
  <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">
    <div style="display:flex;align-items:center;gap:6px;">
      <% if match.live? %>
        <span style="display:inline-flex;align-items:center;gap:4px;background:#ef4444;color:white;font-size:10px;font-weight:700;padding:3px 7px;border-radius:20px;letter-spacing:0.04em;text-transform:uppercase;">
          <span style="width:5px;height:5px;background:white;border-radius:50%;animation:livepulse 1.2s ease-in-out infinite;flex-shrink:0;display:inline-block;"></span>
          EN DIRECT<% if match.status == "HT" %> · MT<% elsif match.elapsed.present? %> · <%= match.elapsed %>′<% end %>
        </span>
      <% end %>
      <%= channel_badge(match.tv_channels, small: true) %>
    </div>
    <span style="font-size:10px;color:var(--color-muted);font-family:'DM Sans',sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px;"><%= match.competition %></span>
  </div>

</div>
<% end %>
<% end %>
