<%#
  Partial : carte affilié DAZN
  Locals :
    - variant      (:standard | :urgent | :compact)  default: :standard
    - match        (objet Match optionnel, pour l'urgence temporelle)
    - page_context (string GA4 : 'match', 'channel', 'competition', 'blog', 'standing') default: 'site'
    - cta_index    (0..2 pour A/B CTA) default: 0
    - subtitle     (string optionnel pour surcharger le texte sous le titre)
%>
<% dazn_url     = "https://dazn.prf.hn/click/camref:1100l5JbRk" %>
<% variant      = local_assigns.fetch(:variant, :standard) %>
<% page_context = local_assigns.fetch(:page_context, "site") %>
<% cta_index    = local_assigns.fetch(:cta_index, 0) %>
<% match        = local_assigns.fetch(:match, nil) %>
<% ctas = ["Regarder en direct sur DAZN", "Voir ce match sur DAZN", "S'abonner à DAZN"] %>
<% cta_text  = ctas[cta_index % 3] %>
<% ga_push   = "dataLayer.push({event:'affiliate_click',affiliate_partner:'dazn',affiliate_page:'#{page_context}',affiliate_cta:#{cta_index % 3}})" %>

<% if variant == :compact %>
  <%# Lien inline sans card %>
  <%= link_to dazn_url, target: "_blank", rel: "nofollow sponsored noopener",
      style: "color: #3b82f6; font-weight: 600; text-decoration: none;",
      onclick: ga_push do %>
    <%= cta_text %> →
  <% end %>

<% else %>
  <%# Calcul urgence si match fourni %>
  <% urgent_label = nil %>
  <% if match.present? && match.respond_to?(:start_time) && match.start_time > Time.current %>
    <% mins = ((match.start_time - Time.current) / 60).to_i %>
    <% if mins < 60 %>
      <% urgent_label = "Match dans #{mins} min" %>
    <% elsif mins < 180 %>
      <% urgent_label = "Match dans #{(mins / 60.0).ceil}h" %>
    <% end %>
  <% end %>

  <%# Texte sous le titre %>
  <% card_subtitle = local_assigns[:subtitle].presence ||
    (urgent_label ? "Ce match est diffusé en direct sur DAZN. Abonnez-vous en 2 minutes." :
                    "Serie A, Eredivisie et Ligue 1 - regardez le foot en direct sur DAZN.") %>

  <div style="background: white; border: 1px solid #bfdbfe; border-radius: 10px; padding: 18px 20px; margin: 22px 0; box-shadow: 0 2px 8px rgba(59,130,246,0.07);">
    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap;">
      <span style="font-size: 16px; font-weight: 900; letter-spacing: -0.5px; color: #fff; background: #010e1b; border-radius: 4px; padding: 2px 9px;">DAZN</span>
      <% if urgent_label %>
        <span style="background: #fef2f2; color: #ef4444; font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.04em;"><%= urgent_label %></span>
      <% end %>
    </div>
    <p style="margin: 0 0 16px; font-size: 14px; color: #475569; line-height: 1.5;"><%= card_subtitle %></p>
    <div style="text-align: center;">
      <%= link_to dazn_url, target: "_blank", rel: "nofollow sponsored noopener",
          onclick: ga_push,
          style: "display: inline-block; background: #3b82f6; color: white; font-size: 14px; font-weight: 700; padding: 11px 24px; border-radius: 6px; text-decoration: none; transition: background 0.15s;",
          onmouseover: "this.style.background='#2563eb'",
          onmouseout:  "this.style.background='#3b82f6'" do %>
        <%= cta_text %> →
      <% end %>
    </div>
  </div>
<% end %>
