<%#
  Partial : matchs CdM 2026 des prochains jours (groupés par date)
  Locals :
    - upcoming_by_date : Hash { Date => [Match, ...] } trié par date (3-4 prochains jours)
    - tournament_over  : true si Mondial terminé
%>
<% upcoming_by_date = local_assigns.fetch(:upcoming_by_date, {}) %>
<% tournament_over  = local_assigns.fetch(:tournament_over, false) %>

<% if tournament_over %>
  <div style="margin: 20px 0; padding: 20px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; text-align: center;">
    <p style="font-size: 14px; color: #64748b; margin: 0;">
      La Coupe du Monde 2026 est terminée. Retrouve tous les résultats sur la
      <a href="/competitions/coupe-du-monde-2026" style="color: var(--color-accent); font-weight: 600; text-decoration: none;">page compétition</a>.
    </p>
  </div>

<% elsif upcoming_by_date.any? %>
  <div style="margin: 20px 0;">
    <% upcoming_by_date.each do |date, matches| %>
      <div style="margin-bottom: 16px;">
        <p style="font-size: 12px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 8px;">
          <%= I18n.l(date, format: '%A %d %B').capitalize rescue date.strftime('%d/%m/%Y') %>
          <span style="font-weight: 400; color: #94a3b8;"> - <%= matches.size %> match<%= matches.size > 1 ? 's' : '' %></span>
        </p>
        <div style="display: flex; flex-direction: column; gap: 4px;">
          <% matches.each do |match| %>
            <%= render 'shared/match_card', match: match, priority: false %>
          <% end %>
        </div>
      </div>
    <% end %>
    <p style="font-size: 11px; color: #94a3b8; margin: 4px 0 0; text-align: right;">
      Mis à jour toutes les heures -
      <a href="/competitions/coupe-du-monde-2026" style="color: var(--color-accent); text-decoration: none; font-weight: 600;">Voir le calendrier complet →</a>
    </p>
  </div>

<% else %>
  <div style="margin: 20px 0; padding: 20px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; text-align: center;">
    <p style="font-size: 14px; color: #64748b; margin: 0;">
      Aucun match programmé pour les prochains jours.
      Le <a href="/blog/calendrier-france-mondial-2026" style="color: var(--color-accent); font-weight: 600; text-decoration: none;">calendrier complet</a> est disponible ici.
    </p>
  </div>
<% end %>
