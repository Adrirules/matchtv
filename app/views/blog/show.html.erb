<% content_for :title, @page_title %>
<% content_for :meta_description, @page_desc %>

<% content_for :json_ld do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "<%= @article[:title]&.gsub(' | Coup d\'Envoi TV', '')&.gsub('"', '\"') %>",
  "datePublished": "<%= @article[:published_at]&.to_date&.iso8601 %>",
  "dateModified": "<%= @article[:published_at]&.to_date&.iso8601 %>",
  "author": { "@type": "Person", "name": "Adrien" },
  "publisher": {
    "@type": "Organization",
    "name": "Coup d'Envoi TV",
    "url": "https://www.coupdenvoi.tv"
  },
  "description": "<%= @article[:meta_description]&.gsub('"', '\"') %>"
}
</script>
<% end %>

<div class="blog-wrapper">
<article class="blog-card">

  <%# Fil d'Ariane %>
  <nav style="font-size: 12px; color: #999; margin-bottom: 20px;">
    <%= link_to "Accueil", root_path, style: "color: #999; text-decoration: none;" %> ›
    <%= link_to "Blog", blog_path, style: "color: #999; text-decoration: none;" %> ›
    <span><%= @article[:title]&.gsub(' | Coup d\'Envoi TV', '')&.truncate(60) %></span>
  </nav>

  <%# Métadonnées auteur %>
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 28px;">
    <div style="width: 36px; height: 36px; border-radius: 50%; background: #010e1b; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 15px; flex-shrink: 0;">A</div>
    <div>
      <span style="font-weight: 600; font-size: 14px; color: #010e1b;">Adrien</span>
      <span style="color: #999; font-size: 13px; margin-left: 8px;">·</span>
      <time datetime="<%= @article[:published_at] %>" style="font-size: 13px; color: #999; margin-left: 8px;">
        <%= date_fr(@article[:published_at]) %>
      </time>
    </div>
  </div>

  <%# Sommaire automatique %>
  <% if @toc.length >= 2 %>
    <nav class="blog-toc">
      <p class="blog-toc-title">Dans cet article</p>
      <ol>
        <% @toc.each do |item| %>
          <li><%= link_to item[:text], "##{item[:anchor]}" %></li>
        <% end %>
      </ol>
    </nav>
  <% end %>

  <%# Corps de l'article %>
  <div class="blog-content">
    <%= @article_html %>
  </div>

  <%# Prochains derbies (dynamique) %>
  <% if @derby_matches.any? %>
    <div style="margin-top: 40px; padding-top: 32px; border-top: 1px solid #e2e8f0;">
      <h2 style="font-size: 18px; font-weight: 700; color: #010e1b; margin: 0 0 16px;"><%= @article[:match_pairs_title].presence || "Les prochains derbies" %></h2>
      <div style="display: flex; flex-direction: column; gap: 10px;">
        <% @derby_matches.each do |match| %>
          <%= link_to match_path(match.slug), style: "display:block; text-decoration:none; color:inherit;" do %>
            <div style="border: 1px solid #e2e8f0; border-radius: 6px; padding: 14px 16px; background: #fff; transition: all 0.15s;" onmouseover="this.style.borderColor='#3b82f6';this.style.background='#f8faff'" onmouseout="this.style.borderColor='#e2e8f0';this.style.background='#fff'">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0;">
                  <% if match.home_team_logo.present? %>
                    <img src="<%= match.home_team_logo %>" alt="<%= match.home_team %>" width="24" height="24" style="object-fit:contain; flex-shrink:0;" loading="lazy">
                  <% end %>
                  <span style="font-weight: 600; font-size: 14px; color: #010e1b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= team_display_name(match.home_team) %></span>
                  <span style="color: #94a3b8; font-size: 13px; font-weight: 500; flex-shrink: 0;">vs</span>
                  <span style="font-weight: 600; font-size: 14px; color: #010e1b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= team_display_name(match.away_team) %></span>
                  <% if match.away_team_logo.present? %>
                    <img src="<%= match.away_team_logo %>" alt="<%= match.away_team %>" width="24" height="24" style="object-fit:contain; flex-shrink:0;" loading="lazy">
                  <% end %>
                </div>
                <div style="text-align: right; flex-shrink: 0;">
                  <div style="font-size: 13px; font-weight: 600; color: #010e1b;">
                    <% if match.status == 'NS' %>
                      <%= "#{match.start_time.day} #{ApplicationHelper::MONTHS_FR[match.start_time.month - 1]}, #{match.start_time.strftime('%Hh%M')}" %>
                    <% else %>
                      <span style="color: #ef4444;">En direct</span>
                    <% end %>
                  </div>
                  <% if match.tv_channels.present? %>
                    <div style="font-size: 11px; color: #64748b; margin-top: 2px;"><%= match.tv_channels.split(',').first&.strip %></div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Matchs groupés par groupe/compétition %>
  <% if @match_groups.any? %>
    <div style="margin-top: 40px; padding-top: 32px; border-top: 1px solid #e2e8f0;">
      <h2 style="font-size: 18px; font-weight: 700; color: #010e1b; margin: 0 0 20px;"><%= @article[:match_pairs_title].presence || "Les matchs à ne pas rater" %></h2>
      <% @match_groups.each do |group| %>
        <p style="font-size: 12px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 8px;"><%= group[:name] %></p>
        <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;">
          <% group[:matches].each do |match| %>
            <%= link_to match_path(match.slug), style: "display:block; text-decoration:none; color:inherit;" do %>
              <div style="border: 1px solid #e2e8f0; border-radius: 6px; padding: 14px 16px; background: #fff; transition: all 0.15s;" onmouseover="this.style.borderColor='#3b82f6';this.style.background='#f8faff'" onmouseout="this.style.borderColor='#e2e8f0';this.style.background='#fff'">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                  <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0;">
                    <% if match.home_team_logo.present? %>
                      <img src="<%= match.home_team_logo %>" alt="<%= match.home_team %>" width="24" height="24" style="object-fit:contain; flex-shrink:0;" loading="lazy">
                    <% end %>
                    <span style="font-weight: 600; font-size: 14px; color: #010e1b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= team_display_name(match.home_team) %></span>
                    <span style="color: #94a3b8; font-size: 13px; font-weight: 500; flex-shrink: 0;">vs</span>
                    <span style="font-weight: 600; font-size: 14px; color: #010e1b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= team_display_name(match.away_team) %></span>
                    <% if match.away_team_logo.present? %>
                      <img src="<%= match.away_team_logo %>" alt="<%= match.away_team %>" width="24" height="24" style="object-fit:contain; flex-shrink:0;" loading="lazy">
                    <% end %>
                  </div>
                  <div style="text-align: right; flex-shrink: 0;">
                    <div style="font-size: 13px; font-weight: 600; color: #010e1b;">
                      <% if match.status == 'NS' %>
                        <%= "#{match.start_time.day} #{ApplicationHelper::MONTHS_FR[match.start_time.month - 1]}, #{match.start_time.strftime('%Hh%M')}" %>
                      <% else %>
                        <span style="color: #ef4444;">En direct</span>
                      <% end %>
                    </div>
                    <% if match.tv_channels.present? %>
                      <div style="font-size: 11px; color: #64748b; margin-top: 2px;"><%= match.tv_channels.split(',').first&.strip %></div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Bio auteur %>
  <div style="margin-top: 48px; padding: 20px; background: #f8f9fa; border-left: 3px solid #010e1b; border-radius: 4px;">
    <p style="font-size: 14px; font-weight: 700; margin: 0 0 6px; color: #010e1b;">Adrien</p>
    <p style="font-size: 14px; color: #555; margin: 0; line-height: 1.6;">Passionné de foot depuis toujours, je gère coupdenvoi.tv pour que personne ne rate un match faute d'avoir trouvé la bonne chaîne. Je suis les transferts, les classements et les droits TV de près, surtout quand ça change aussi vite qu'en ce moment.</p>
  </div>

  <%# Retour blog %>
  <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #eee;">
    <%= link_to "← Retour au blog", blog_path, style: "font-size: 14px; color: #1a73e8; text-decoration: none;" %>
  </div>

</article>
</div>
