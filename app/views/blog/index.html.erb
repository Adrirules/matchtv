<% content_for :title, @page_title %>
<% content_for :meta_description, @page_desc %>

<%# rel="prev"/"next" pour Google — signaux de pagination %>
<% content_for :json_ld do %>
  <% if @current_page > 1 %>
    <link rel="prev" href="<%= blog_path(page: @current_page - 1) %>">
  <% end %>
  <% if @current_page < @total_pages %>
    <link rel="next" href="<%= blog_path(page: @current_page + 1) %>">
  <% end %>
<% end %>

<div class="blog-wrapper">
  <h1 style="font-size: 26px; font-weight: 800; margin: 0 0 6px;">Blog foot</h1>
  <p style="color: #666; font-size: 15px; margin-bottom: 24px;">Guides pratiques, comparatifs d'abonnements et analyses rédigés par Adrien.</p>

  <% if @articles.empty? %>
    <p style="color: #999;">Aucun article pour le moment.</p>
  <% else %>
    <% @articles.each do |article| %>
      <article class="blog-card" style="margin-bottom: 20px; padding: 0; overflow: hidden;">
        <% if article[:image].present? %>
          <div style="position: relative;">
            <%= link_to blog_article_path(article[:slug]) do %>
              <img src="<%= article[:image] %>" alt="<%= article[:title]&.gsub(' | Coup d\'Envoi TV', '') %>" loading="lazy" width="800" height="200" style="width:100%;height:200px;object-fit:cover;display:block;">
            <% end %>
          </div>
        <% end %>
        <div style="padding: 20px 24px 24px;">
          <time datetime="<%= article[:published_at] %>" style="font-size: 12px; color: #999; display: block; margin-bottom: 6px;">
            <%= date_fr(article[:published_at]) %>
          </time>
          <h2 style="font-size: 20px; font-weight: 700; margin: 0 0 10px;">
            <%= link_to article[:title]&.gsub(' | Coup d\'Envoi TV', ''), blog_article_path(article[:slug]),
                style: "color: #010e1b; text-decoration: none;" %>
          </h2>
          <% if article[:excerpt].present? %>
            <p style="color: #555; font-size: 15px; line-height: 1.6; margin: 0 0 14px;"><%= article[:excerpt] %></p>
          <% end %>
          <%= link_to "Lire l'article →", blog_article_path(article[:slug]),
              style: "font-size: 14px; font-weight: 600; color: #1a73e8; text-decoration: none;" %>
        </div>
      </article>
    <% end %>

    <%# Pagination — uniquement si plusieurs pages %>
    <% if @total_pages > 1 %>
      <nav aria-label="Navigation articles" style="display: flex; align-items: center; justify-content: center; gap: 8px; margin: 32px 0 16px;">

        <%# Précédent %>
        <% if @current_page > 1 %>
          <%= link_to blog_path(page: @current_page - 1),
              style: "display: inline-flex; align-items: center; gap: 4px; padding: 8px 14px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; font-weight: 500; color: #475569; text-decoration: none; background: #fff; transition: all 0.15s;",
              onmouseover: "this.style.borderColor='#3b82f6';this.style.color='#3b82f6'",
              onmouseout:  "this.style.borderColor='#e2e8f0';this.style.color='#475569'" do %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            Précédent
          <% end %>
        <% end %>

        <%# Numéros de pages %>
        <% (1..@total_pages).each do |p| %>
          <% if p == @current_page %>
            <span style="display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 6px; font-size: 14px; font-weight: 700; background: #010e1b; color: #fff;">
              <%= p %>
            </span>
          <% else %>
            <%= link_to p, blog_path(page: p),
                style: "display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; font-weight: 500; color: #475569; text-decoration: none; background: #fff; transition: all 0.15s;",
                onmouseover: "this.style.borderColor='#3b82f6';this.style.color='#3b82f6'",
                onmouseout:  "this.style.borderColor='#e2e8f0';this.style.color='#475569'" %>
          <% end %>
        <% end %>

        <%# Suivant %>
        <% if @current_page < @total_pages %>
          <%= link_to blog_path(page: @current_page + 1),
              style: "display: inline-flex; align-items: center; gap: 4px; padding: 8px 14px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; font-weight: 500; color: #475569; text-decoration: none; background: #fff; transition: all 0.15s;",
              onmouseover: "this.style.borderColor='#3b82f6';this.style.color='#3b82f6'",
              onmouseout:  "this.style.borderColor='#e2e8f0';this.style.color='#475569'" do %>
            Suivant
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          <% end %>
        <% end %>

      </nav>
    <% end %>

  <% end %>
</div>
