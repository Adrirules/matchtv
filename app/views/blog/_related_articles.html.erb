<%# Partial : "Vous aimerez aussi"
    Locals : related_articles (array of article hashes) %>

<% related = local_assigns.fetch(:related_articles, []) %>

<% tag_labels = BlogController::TAG_LABELS %>

<% if related.any? %>
  <div style="margin-top: 40px; padding-top: 32px; border-top: 1px solid #e2e8f0;">
    <h2 style="font-size: 18px; font-weight: 700; color: #010e1b; margin: 0 0 20px;">Vous aimerez aussi</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px;">
      <% related.each do |rel| %>
        <%= link_to blog_article_path(rel[:slug]), style: "text-decoration: none; color: inherit;" do %>
          <div style="border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; background: #fff; transition: all 0.15s; height: 100%;"
               onmouseover="this.style.borderColor='#3b82f6'; this.style.boxShadow='0 2px 10px rgba(59,130,246,0.1)'"
               onmouseout="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'">
            <% if rel[:image].present? %>
              <div style="height: 130px; overflow: hidden;">
                <img src="<%= rel[:image] %>" alt="<%= rel[:title] %>"
                     width="400" height="130"
                     style="width: 100%; height: 100%; object-fit: cover;"
                     loading="lazy">
              </div>
            <% end %>
            <div style="padding: 12px 14px;">
              <% if rel[:tags]&.any? %>
                <span style="display: inline-block; background: #eff6ff; color: #3b82f6; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 20px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.04em;">
                  <%= tag_labels[rel[:tags].first] || rel[:tags].first.gsub('-', ' ').capitalize %>
                </span>
              <% end %>
              <p style="margin: 0; font-size: 14px; font-weight: 700; color: #010e1b; line-height: 1.4;"><%= rel[:title]&.gsub(/ \| Coup d'Envoi TV$/, '') %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
