<!DOCTYPE html>
<html lang="fr">
  <head>
    <script type="text/javascript">(function(i,m,p,a,c,t){c.ire_o=p;c[p]=c[p]||function(){(c[p].a=c[p].a||[]).push(arguments)};t=a.createElement(m);var z=a.getElementsByTagName(m)[0];t.async=1;t.src=i;z.parentNode.insertBefore(t,z)})('https://utt.impactcdn.com/P-A7376919-3d5b-4dda-9cec-008cdd9186891.js','script','impactStat',document,window);impactStat('transformLinks');impactStat('trackImpression');</script>
    <meta charset="utf-8">
    <title><%= content_for?(:title) ? yield(:title) : "Coup d'envoi | Programme TV Sport : Sur quelle chaîne voir le match ?" %></title>

    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Découvrez le programme TV foot et rugby complet pour 2026 : horaires, chaînes (Canal+, beIN, DAZN, TF1) et streaming en direct." %>">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="canonical" href="<%= request.base_url + request.path %>">
    <% if @noindex %><meta name="robots" content="noindex, follow"><% end %>

    <%# Open Graph / SEO (Facebook, WhatsApp, LinkedIn) %>
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : "Coup d'envoi" %>">
    <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Le programme TV sport le plus complet et rapide." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.base_url + request.path %>">
    <meta property="og:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "https://www.coupdenvoi.tv/icon-512.png" %>">
    <meta property="og:image:width" content="<%= content_for?(:og_image) ? 1200 : 1024 %>">
    <meta property="og:image:height" content="<%= content_for?(:og_image) ? 630 : 1024 %>">
    <meta property="og:site_name" content="Coup d'Envoi TV">
    <meta property="og:locale" content="fr_FR">

    <%# Twitter Cards %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : "Coup d'envoi" %>">
    <meta name="twitter:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Le programme TV sport le plus complet et rapide." %>">
    <meta name="twitter:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "https://www.coupdenvoi.tv/icon-512.png" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Preconnect pour réduire la latence réseau %>
    <%# Fonts - chargement asynchrone (non bloquant) via preload/onload %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"></noscript>

    <%# Preconnect CDN logos équipes (améliore le LCP) %>
    <link rel="preconnect" href="https://media.api-sports.io">
    <link rel="dns-prefetch" href="https://media.api-sports.io">
    <link rel="dns-prefetch" href="https://www.googletagmanager.com">

    <%# CSS critique inline — évite le render-blocking de Bootstrap/FA %>
    <style>
:root{--color-bg:#EFF2F6;--bs-body-bg:#EFF2F6;--color-surface:#fff;--color-border:oklch(88% .012 255);--color-accent:oklch(40% .2 255);--color-accent-dim:oklch(40% .2 255/.1);--color-text:oklch(14% .02 255);--color-muted:oklch(52% .02 255);--color-header:oklch(20% .08 255);--color-live:oklch(50% .22 25);--font-heading:'Barlow Condensed',sans-serif;--font-body:'DM Sans',sans-serif}
html,body{height:100%;margin:0;padding:0;overflow-x:hidden;overscroll-behavior-y:none}
body{display:flex;flex-direction:column;width:100%;background:var(--color-bg);font-family:var(--font-body);color:var(--color-text)}
.top-nav{padding:10px 16px;background:var(--color-header);font-weight:700;font-size:18px;display:flex;align-items:center;justify-content:space-between}
.top-nav a{color:#fff;text-decoration:none}
.top-nav-logo{font-family:var(--font-heading);font-weight:800;font-size:20px;letter-spacing:-.01em;color:#fff}
.top-nav-blog-mobile{font-size:13px;font-weight:700;color:rgba(255,255,255,.75);text-decoration:none;padding:5px 10px;border-radius:8px;border:1px solid rgba(255,255,255,.2);white-space:nowrap}
.bottom-nav{position:fixed;bottom:0;left:0;width:100%;background:#fff;border-top:1px solid #eaeaea;display:flex;justify-content:space-around;padding:10px 0;z-index:1000}
main{padding-bottom:70px}
.container{width:100%;padding-right:15px;padding-left:15px;margin-right:auto;margin-left:auto}
.blog-wrapper{max-width:1100px;margin:0 auto;padding:30px 15px}
.blog-card{background:#fff;border-radius:8px;box-shadow:0 1px 6px rgba(0,0,0,.07);padding:36px 48px;max-width:900px;margin:0 auto}
@media(max-width:768px){.blog-card{padding:24px 20px}}
@media(max-width:600px){.blog-wrapper{padding:20px 12px}.blog-card{padding:22px 18px}}
@media(min-width:1024px){.bottom-nav{display:none}main{padding-bottom:0}.top-nav-blog-mobile{display:none}.top-nav-links{display:flex;align-items:center;gap:4px}}
    </style>
    <%# application.css en async (non render-blocking) — noscript fallback %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload", media: "print", onload: "this.media='all'" %>
    <noscript><%= stylesheet_link_tag "application" %></noscript>
    <%= javascript_importmap_tags %>

    <%# Configuration PWA & Mobile 2026 %>
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Coup d'envoi">
    <meta name="theme-color" content="#010e1b">

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icon-512.png">
    <link rel="icon" type="image/png" href="/icon-512.png">
    <link rel="alternate" type="application/rss+xml" title="Coup d'Envoi TV - Blog football" href="/blog.rss">

    <%# WebSite schema %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Coup d'Envoi TV",
      "url": "https://www.coupdenvoi.tv",
      "description": "Programme TV football : retrouvez sur quelle chaîne voir chaque match en direct."
    }
    </script>

    <%= yield :json_ld %>

    <%# AdSense — uniquement sur les pages avec contenu (pas sur noindex) %>
    <% unless @noindex %>
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1509060692668087" crossorigin="anonymous"></script>
    <% end %>

    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-T49VLVWX');</script>
  </head>

  <body>
    <%= render "shared/top_nav" %>

    <% if content_for?(:calendar) %>
      <div class="calendar-full-width-bg">
        <div class="sticky-calendar">
          <%= yield :calendar %>
        </div>
      </div>
    <% end %>

    <% if content_for?(:hero) %>
      <%= yield :hero %>
    <% end %>

    <main class="container<%= " #{content_for(:container_class)}" if content_for?(:container_class) %>">
      <%= yield %>
    </main>

    <%= render "shared/bottom_nav" %>
    <%= render "shared/footer" %>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T49VLVWX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <script>
    document.querySelectorAll('a[href]').forEach(function(a) {
      try {
        var url = new URL(a.getAttribute('href'), window.location.href);
        if (url.hostname !== window.location.hostname) {
          a.setAttribute('target', '_blank');
          if (!a.rel.includes('noopener')) a.rel = (a.rel ? a.rel + ' ' : '') + 'noopener';
        }
      } catch(e) {}
    });
    </script>
  </body>
</html>
