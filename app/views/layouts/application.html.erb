<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <title><%= content_for?(:title) ? yield(:title) : "Coup d'envoi | Programme TV Sport : Sur quelle chaîne voir le match ?" %></title>

    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Découvrez le programme TV foot et rugby complet pour 2026 : horaires, chaînes (Canal+, beIN, DAZN, TF1) et streaming en direct." %>">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="canonical" href="<%= request.original_url %>">

    <%# Open Graph / SEO (Facebook, WhatsApp, LinkedIn) %>
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : "Coup d'envoi" %>">
    <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Le programme TV sport le plus complet et rapide." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "https://www.coupdenvoi.tv/og-default.png" %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="Coup d'envoi">
    <meta property="og:locale" content="fr_FR">

    <%# Twitter Cards %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : "Coup d'envoi" %>">
    <meta name="twitter:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "Le programme TV sport le plus complet et rapide." %>">
    <meta name="twitter:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "https://www.coupdenvoi.tv/og-default.png" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Preconnect pour réduire la latence réseau %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://www.googletagmanager.com">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Configuration PWA & Mobile 2026 %>
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Coup d'envoi">
    <meta name="theme-color" content="#010e1b">

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icon-512.png">
    <link rel="icon" type="image/png" href="/icon-512.png">

    <%# WebSite schema avec SearchAction (Sitelinks Searchbox) %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Coup d'envoi",
      "url": "https://www.coupdenvoi.tv",
      "description": "Programme TV football : retrouvez sur quelle chaîne voir chaque match en direct.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://www.coupdenvoi.tv/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <%# AdSense %>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1509060692668087" crossorigin="anonymous"></script>

    <%# Google CMP (Funding Choices) : ajouter le snippet fourni par AdSense après approbation %>
    <%# [FUNDING CHOICES SNIPPET ICI] %>

    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-T49VLVWX');</script>
  </head>

  <body>
    <%= render "shared/top_nav" %>

    <% if content_for?(:calendar) %>
      <div class="calendar-full-width-bg">
        <div class="sticky-calendar">
          <%= yield :calendar %>
        </div>
      </div>
    <% end %>

    <main class="container">
      <%= yield %>
    </main>

    <%= render "shared/bottom_nav" %>
    <%= render "shared/footer" %>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T49VLVWX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
  </body>
</html>
