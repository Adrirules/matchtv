<% if knockout_rounds.any? %>
<section style="margin: 32px 0;">
  <h2 style="font-size: 20px; font-weight: 600; color: #0f172a; margin: 0 0 20px;">Phases finales</h2>

  <%
    # Ordre canonique des rounds (du plus récent au plus lointain)
    round_order = [
      'Final', 'Finale',
      '3rd Place Final', 'Match pour la 3e place',
      'Semi-finals', 'Demi-finales', 'Semi Finals',
      'Quarter-finals', 'Quarts de finale', 'Quarter Finals',
      'Round of 16', 'Huitièmes de finale', 'Round Of 16',
      'Round of 32', 'Seizièmes de finale', 'Round Of 32',
      '5th Round', '4th Round', '3rd Round', '2nd Round', '1st Round',
      'Round 1', 'Round 2', 'Round 3', 'Round 4', 'Round 5',
    ]

    sorted_rounds = knockout_rounds.sort_by do |name, _|
      idx = round_order.index { |r| r.downcase == name.to_s.downcase }
      idx || 999
    end
  %>

  <% sorted_rounds.each do |round_name, matches| %>
    <div style="margin-bottom: 24px;">
      <h3 style="font-size: 14px; font-weight: 600; color: #475569; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 12px; padding-bottom: 8px; border-bottom: 1px solid #e2e8f0;">
        <%= round_name %>
      </h3>

      <%
        # Regrouper les matchs aller/retour par paires d'équipes
        pairs = {}
        matches.each do |m|
          key = [m.home_team, m.away_team].sort.join('|')
          pairs[key] ||= []
          pairs[key] << m
        end
      %>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px;">
        <% pairs.each do |_key, pair_matches| %>
          <% pair_matches.sort_by(&:start_time).each_with_index do |match, leg_idx| %>
            <%
              is_finished = match.finished?
              home_wins = is_finished && match.home_score.to_i > match.away_score.to_i
              away_wins = is_finished && match.away_score.to_i > match.home_score.to_i
              leg_label = pair_matches.size > 1 ? (leg_idx == 0 ? 'Aller' : 'Retour') : ''
            %>
            <%= link_to match_path(match.slug), style: "display: block; text-decoration: none; color: inherit;" do %>
              <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 6px; padding: 12px 14px; transition: all 0.15s; cursor: pointer;"
                   onmouseover="this.style.borderColor='#94a3b8'; this.style.boxShadow='0 1px 4px rgba(0,0,0,0.06)'"
                   onmouseout="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'">

                <% if leg_label.present? %>
                  <div style="font-size: 11px; color: #94a3b8; margin-bottom: 6px;"><%= leg_label.strip %></div>
                <% end %>

                <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                  <%# Équipe domicile %>
                  <div style="display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0;">
                    <% if match.home_team_logo.present? %>
                      <img src="<%= match.home_team_logo %>" alt="" width="18" height="18" style="object-fit: contain; flex-shrink: 0;" loading="lazy">
                    <% end %>
                    <span style="font-size: 13px; font-weight: <%= home_wins ? '600' : '400' %>; color: <%= home_wins ? '#0f172a' : '#334155' %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                      <%= team_display_name(match.home_team) %>
                    </span>
                  </div>

                  <%# Score / heure %>
                  <div style="flex-shrink: 0; text-align: center; min-width: 50px;">
                    <% if is_finished %>
                      <span style="font-size: 15px; font-weight: 700; color: #0f172a;"><%= match.home_score %> - <%= match.away_score %></span>
                    <% else %>
                      <span style="font-size: 12px; color: #64748b;"><%= match.start_time.strftime('%d/%m') %> <%= match.start_time.strftime('%Hh%M') %></span>
                    <% end %>
                  </div>

                  <%# Équipe extérieur %>
                  <div style="display: flex; align-items: center; justify-content: flex-end; gap: 6px; flex: 1; min-width: 0;">
                    <span style="font-size: 13px; font-weight: <%= away_wins ? '600' : '400' %>; color: <%= away_wins ? '#0f172a' : '#334155' %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: right;">
                      <%= team_display_name(match.away_team) %>
                    </span>
                    <% if match.away_team_logo.present? %>
                      <img src="<%= match.away_team_logo %>" alt="" width="18" height="18" style="object-fit: contain; flex-shrink: 0;" loading="lazy">
                    <% end %>
                  </div>
                </div>

                <% if !is_finished && match.tv_channels.present? %>
                  <div style="margin-top: 6px; font-size: 11px; color: #64748b; text-align: center;"><%= match.tv_channels %></div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
<% end %>
