<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Rapport partages — Coup d'Envoi TV</title>
</head>
<body style="margin:0; padding:0; background:#f1f5f9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f1f5f9; padding: 32px 16px;">
  <tr><td align="center">
  <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%;">

    <%# Header %>
    <tr>
      <td style="background:#010e1b; border-radius:8px 8px 0 0; padding:24px 32px;">
        <p style="margin:0; font-size:20px; font-weight:700; color:#fff;">Coup d'Envoi TV</p>
        <p style="margin:4px 0 0; font-size:13px; color:#94a3b8;">Rapport de partages — généré le <%= @generated_at %></p>
      </td>
    </tr>

    <%# Body %>
    <tr>
      <td style="background:#fff; padding:32px; border-radius:0 0 8px 8px;">

        <%# Section : cette semaine avec trends %>
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:36px;">
          <tr>
            <td colspan="5" style="padding-bottom:12px; border-bottom:2px solid #010e1b;">
              <p style="margin:0; font-size:16px; font-weight:700; color:#010e1b;">Cette semaine</p>
              <p style="margin:2px 0 0; font-size:12px; color:#64748b;">du <%= 7.days.ago.strftime('%d/%m') %> au <%= Date.today.strftime('%d/%m') %> — vs semaine précédente</p>
            </td>
          </tr>
          <tr style="border-bottom:1px solid #e2e8f0;">
            <td style="padding:6px 8px 6px 0; width:24px;"></td>
            <td style="padding:6px 8px; font-size:11px; font-weight:600; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em;">Page</td>
            <td style="padding:6px 4px; font-size:11px; font-weight:600; color:#25d366; text-align:right; white-space:nowrap;">WA</td>
            <td style="padding:6px 4px; font-size:11px; font-weight:600; color:#1da1f2; text-align:right; white-space:nowrap;">X</td>
            <td style="padding:6px 0 6px 8px; font-size:11px; font-weight:600; color:#64748b; text-align:right; white-space:nowrap;">Total</td>
          </tr>
          <% if @trends.empty? %>
            <tr><td colspan="5" style="padding:16px 0; color:#94a3b8; font-size:14px;">Aucun partage cette semaine.</td></tr>
          <% else %>
            <% @trends.each_with_index do |row, i| %>
              <tr style="border-bottom:1px solid #f1f5f9;">
                <td style="padding:10px 8px 10px 0; width:24px; font-size:13px; font-weight:700; color:#94a3b8;"><%= i + 1 %></td>
                <td style="padding:10px 8px; font-size:13px; color:#0f172a; word-break:break-all;">
                  <a href="https://www.coupdenvoi.tv<%= row[:url] %>" style="color:#1a73e8; text-decoration:none;"><%= row[:url].truncate(55) %></a>
                </td>
                <td style="padding:10px 4px; text-align:right; font-size:13px; color:#25d366; font-weight:600; white-space:nowrap;"><%= row[:whatsapp] > 0 ? row[:whatsapp] : '-' %></td>
                <td style="padding:10px 4px; text-align:right; font-size:13px; color:#1da1f2; font-weight:600; white-space:nowrap;"><%= row[:x] > 0 ? row[:x] : '-' %></td>
                <td style="padding:10px 0 10px 8px; text-align:right; white-space:nowrap;">
                  <span style="font-size:14px; font-weight:700; color:#0f172a;"><%= row[:total] %></span>
                  <span style="font-size:14px; margin-left:6px; color:<%= row[:trend] == '↑' || row[:trend] == '🆕' ? '#16a34a' : row[:trend] == '↓' ? '#dc2626' : '#64748b' %>;">
                    <%= row[:trend] %>
                  </span>
                </td>
              </tr>
            <% end %>
          <% end %>
        </table>

        <%# Section : ce mois %>
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:36px;">
          <tr>
            <td colspan="5" style="padding-bottom:12px; border-bottom:2px solid #e2e8f0;">
              <p style="margin:0; font-size:16px; font-weight:700; color:#010e1b;">Ce mois-ci</p>
              <p style="margin:2px 0 0; font-size:12px; color:#64748b;">depuis le 1er <%= @month_fr %> <%= @year %></p>
            </td>
          </tr>
          <tr style="border-bottom:1px solid #e2e8f0;">
            <td style="padding:6px 8px 6px 0; width:24px;"></td>
            <td style="padding:6px 8px; font-size:11px; font-weight:600; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em;">Page</td>
            <td style="padding:6px 4px; font-size:11px; font-weight:600; color:#25d366; text-align:right; white-space:nowrap;">WA</td>
            <td style="padding:6px 4px; font-size:11px; font-weight:600; color:#1da1f2; text-align:right; white-space:nowrap;">X</td>
            <td style="padding:6px 0 6px 8px; font-size:11px; font-weight:600; color:#64748b; text-align:right; white-space:nowrap;">Total</td>
          </tr>
          <% if @top_month.empty? %>
            <tr><td colspan="5" style="padding:16px 0; color:#94a3b8; font-size:14px;">Aucun partage ce mois.</td></tr>
          <% else %>
            <% @top_month.each_with_index do |row, i| %>
              <tr style="border-bottom:1px solid #f1f5f9;">
                <td style="padding:10px 8px 10px 0; width:24px; font-size:13px; font-weight:700; color:#94a3b8;"><%= i + 1 %></td>
                <td style="padding:10px 8px; font-size:13px; color:#0f172a; word-break:break-all;">
                  <a href="https://www.coupdenvoi.tv<%= row[:url] %>" style="color:#1a73e8; text-decoration:none;"><%= row[:url].truncate(55) %></a>
                </td>
                <td style="padding:10px 4px; text-align:right; font-size:13px; color:#25d366; font-weight:600; white-space:nowrap;"><%= row[:whatsapp] > 0 ? row[:whatsapp] : '-' %></td>
                <td style="padding:10px 4px; text-align:right; font-size:13px; color:#1da1f2; font-weight:600; white-space:nowrap;"><%= row[:x] > 0 ? row[:x] : '-' %></td>
                <td style="padding:10px 0 10px 8px; text-align:right; font-size:14px; font-weight:700; color:#0f172a; white-space:nowrap;"><%= row[:total] %></td>
              </tr>
            <% end %>
          <% end %>
        </table>

        <%# Section : cette année %>
        <table width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td colspan="5" style="padding-bottom:12px; border-bottom:2px solid #e2e8f0;">
              <p style="margin:0; font-size:16px; font-weight:700; color:#010e1b;">Depuis le 1er janvier <%= @year %></p>
            </td>
          </tr>
          <tr style="border-bottom:1px solid #e2e8f0;">
            <td style="padding:6px 8px 6px 0; width:24px;"></td>
            <td style="padding:6px 8px; font-size:11px; font-weight:600; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em;">Page</td>
            <td style="padding:6px 4px; font-size:11px; font-weight:600; color:#25d366; text-align:right; white-space:nowrap;">WA</td>
            <td style="padding:6px 4px; font-size:11px; font-weight:600; color:#1da1f2; text-align:right; white-space:nowrap;">X</td>
            <td style="padding:6px 0 6px 8px; font-size:11px; font-weight:600; color:#64748b; text-align:right; white-space:nowrap;">Total</td>
          </tr>
          <% if @top_year.empty? %>
            <tr><td colspan="5" style="padding:16px 0; color:#94a3b8; font-size:14px;">Aucun partage cette année.</td></tr>
          <% else %>
            <% @top_year.each_with_index do |row, i| %>
              <tr style="border-bottom:1px solid #f1f5f9;">
                <td style="padding:10px 8px 10px 0; width:24px; font-size:13px; font-weight:700; color:#94a3b8;"><%= i + 1 %></td>
                <td style="padding:10px 8px; font-size:13px; color:#0f172a; word-break:break-all;">
                  <a href="https://www.coupdenvoi.tv<%= row[:url] %>" style="color:#1a73e8; text-decoration:none;"><%= row[:url].truncate(55) %></a>
                </td>
                <td style="padding:10px 4px; text-align:right; font-size:13px; color:#25d366; font-weight:600; white-space:nowrap;"><%= row[:whatsapp] > 0 ? row[:whatsapp] : '-' %></td>
                <td style="padding:10px 4px; text-align:right; font-size:13px; color:#1da1f2; font-weight:600; white-space:nowrap;"><%= row[:x] > 0 ? row[:x] : '-' %></td>
                <td style="padding:10px 0 10px 8px; text-align:right; font-size:14px; font-weight:700; color:#0f172a; white-space:nowrap;"><%= row[:total] %></td>
              </tr>
            <% end %>
          <% end %>
        </table>

      </td>
    </tr>

    <%# Footer %>
    <tr>
      <td style="padding:20px 0; text-align:center;">
        <p style="margin:0; font-size:12px; color:#94a3b8;">
          Coup d'Envoi TV · <a href="https://www.coupdenvoi.tv" style="color:#94a3b8;">coupdenvoi.tv</a>
        </p>
      </td>
    </tr>

  </table>
  </td></tr>
</table>

</body>
</html>
