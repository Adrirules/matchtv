<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Rapport SEO — Coup d'Envoi TV</title>
</head>
<body style="margin:0; padding:0; background:#f1f5f9; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f1f5f9; padding:32px 16px;">
  <tr><td align="center">
  <table width="620" cellpadding="0" cellspacing="0" style="max-width:620px; width:100%;">

    <%# Header %>
    <tr>
      <td style="background:#010e1b; border-radius:8px 8px 0 0; padding:24px 32px;">
        <p style="margin:0; font-size:20px; font-weight:700; color:#fff;">Coup d'Envoi TV — Rapport SEO</p>
        <p style="margin:4px 0 0; font-size:13px; color:#94a3b8;">Semaine du <%= @week_label %></p>
      </td>
    </tr>

    <%# Body %>
    <tr>
      <td style="background:#fff; padding:32px; border-radius:0 0 8px 8px;">

        <%# KPIs summary %>
        <%= render 'seo_report_mailer/summary_kpis', summary: @summary, summary_prev: @summary_prev %>

        <%# Analyse Groq %>
        <% if @analysis.present? %>
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:32px;">
          <tr>
            <td style="background:#f0f9ff; border-left:3px solid #3b82f6; padding:16px 20px; border-radius:0 6px 6px 0;">
              <p style="margin:0 0 8px; font-size:13px; font-weight:700; color:#1e40af;">Analyse contextuelle</p>
              <p style="margin:0; font-size:13px; color:#1e3a5f; line-height:1.6; white-space:pre-line;"><%= @analysis %></p>
            </td>
          </tr>
        </table>
        <% end %>

        <%# Top pages %>
        <%= render 'seo_report_mailer/pages_table',
          pages: @trends.first(15),
          title: "Top pages cette semaine",
          subtitle: nil,
          border_color: '#010e1b' %>

        <%# Opportunités %>
        <% if @opportunities.any? %>
          <%= render 'seo_report_mailer/pages_table',
            pages: @opportunities,
            title: "Opportunités — CTR à améliorer",
            subtitle: "Impressions > 200, CTR < 3%, position 8-30",
            border_color: '#f59e0b' %>
        <% end %>

        <%# Pages en recul %>
        <% if @declines.any? %>
          <%= render 'seo_report_mailer/pages_table',
            pages: @declines,
            title: "Pages en recul",
            subtitle: "Position dégradée > 3 places vs semaine précédente",
            border_color: '#ef4444' %>
        <% end %>

      </td>
    </tr>

    <%# Footer %>
    <tr>
      <td style="padding:20px 0; text-align:center;">
        <p style="margin:0; font-size:12px; color:#94a3b8;">
          Coup d'Envoi TV · <a href="https://www.coupdenvoi.tv" style="color:#94a3b8;">coupdenvoi.tv</a>
        </p>
      </td>
    </tr>

  </table>
  </td></tr>
</table>

</body>
</html>
