<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:32px;">
  <tr style="border-bottom:2px solid <%= border_color %>;">
    <td colspan="6" style="padding-bottom:10px;">
      <p style="margin:0; font-size:16px; font-weight:700; color:#010e1b;"><%= title %></p>
      <% if subtitle.present? %><p style="margin:2px 0 0; font-size:12px; color:#64748b;"><%= subtitle %></p><% end %>
    </td>
  </tr>
  <tr style="border-bottom:1px solid #e2e8f0;">
    <td style="padding:6px 4px; font-size:10px; font-weight:600; color:#94a3b8; width:20px;">#</td>
    <td style="padding:6px 8px; font-size:10px; font-weight:600; color:#94a3b8;">Page</td>
    <td style="padding:6px 4px; font-size:10px; font-weight:600; color:#94a3b8; text-align:right;">Imp.</td>
    <td style="padding:6px 4px; font-size:10px; font-weight:600; color:#94a3b8; text-align:right;">Clics</td>
    <td style="padding:6px 4px; font-size:10px; font-weight:600; color:#94a3b8; text-align:right;">CTR</td>
    <td style="padding:6px 0; font-size:10px; font-weight:600; color:#94a3b8; text-align:right; white-space:nowrap;">Pos. Δ</td>
  </tr>
  <% pages.each_with_index do |row, i| %>
    <tr style="border-bottom:1px solid #f1f5f9;">
      <td style="padding:8px 4px; font-size:12px; color:#94a3b8; font-weight:700;"><%= i + 1 %></td>
      <td style="padding:8px; font-size:12px; color:#0f172a; word-break:break-all;">
        <a href="https://www.coupdenvoi.tv<%= row[:page] %>" style="color:#1a73e8; text-decoration:none;"><%= row[:page].truncate(50) %></a>
        <% if row[:is_new] %><span style="font-size:10px; color:#16a34a; margin-left:4px;">NEW</span><% end %>
      </td>
      <td style="padding:8px 4px; font-size:12px; font-weight:600; color:#0f172a; text-align:right;"><%= number_with_delimiter(row[:impressions]) %></td>
      <td style="padding:8px 4px; font-size:12px; color:#0f172a; text-align:right;"><%= row[:clicks] %></td>
      <td style="padding:8px 4px; font-size:12px; color:#0f172a; text-align:right;"><%= row[:ctr] %>%</td>
      <td style="padding:8px 0; font-size:12px; text-align:right; white-space:nowrap;">
        <span style="color:#64748b;"><%= row[:position] %></span>
        <% if row[:delta_pos] %>
          <span style="font-size:11px; margin-left:3px; color:<%= row[:delta_pos] < 0 ? '#16a34a' : row[:delta_pos] > 0 ? '#dc2626' : '#94a3b8' %>;">
            <%= row[:delta_pos] < 0 ? "↑#{row[:delta_pos].abs}" : row[:delta_pos] > 0 ? "↓#{row[:delta_pos]}" : "=" %>
          </span>
        <% end %>
      </td>
    </tr>
  <% end %>
</table>
