<%
  def delta_color(val); val.to_f >= 0 ? '#16a34a' : '#dc2626'; end
  def delta_str(curr, prev, unit: '')
    return '<span style="color:#94a3b8">N/A</span>' if prev.nil? || prev.to_f == 0
    pct = ((curr.to_f / prev.to_f) - 1) * 100
    color = pct >= 0 ? '#16a34a' : '#dc2626'
    sign  = pct >= 0 ? '+' : ''
    "<span style='color:#{color};font-size:12px;'>#{sign}#{pct.round(0)}%</span>"
  end
%>
<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
  <tr>
    <% [
      { label: 'Clics',       val: summary[:clicks],      prev: summary_prev[:clicks] },
      { label: 'Impressions', val: summary[:impressions], prev: summary_prev[:impressions] },
      { label: 'CTR moyen',   val: "#{summary[:ctr]}%",   prev: nil },
      { label: 'Position moy.', val: summary[:position],  prev: nil }
    ].each do |kpi| %>
    <td style="text-align:center; padding:16px 8px; background:#f8fafc; border-radius:6px; margin:0 4px;">
      <p style="margin:0; font-size:11px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em;"><%= kpi[:label] %></p>
      <p style="margin:4px 0 2px; font-size:22px; font-weight:700; color:#0f172a;"><%= number_with_delimiter(kpi[:val]) %></p>
      <% if kpi[:prev] %>
        <%= delta_str(kpi[:val], kpi[:prev]).html_safe %>
      <% end %>
    </td>
    <% end %>
  </tr>
</table>
