<%
  day_labels = { 0 => "Dim.", 1 => "Lun.", 2 => "Mar.", 3 => "Mer.", 4 => "Jeu.", 5 => "Ven.", 6 => "Sam." }

  date_label =
    if @date == Date.today - 1.day
      "hier"
    else
      l(@date, format: "%d %B %Y")
    end
%>

<%# --- SEO --- %>
<% content_for :title, "Résultats foot #{date_label} – Scores et résultats des matchs" %>
<% content_for :meta_description, "Retrouvez les résultats et scores des matchs de football #{date_label} : buts, équipes et compétitions." %>

<%# --- CALENDRIER (7 jours vers le passé) --- %>
<% content_for :calendar do %>
  <% day_labels_map = { 0 => "Dim.", 1 => "Lun.", 2 => "Mar.", 3 => "Mer.", 4 => "Jeu.", 5 => "Ven.", 6 => "Sam." } %>
  <% @days.each do |day| %>
    <%= link_to resultat_date_path(day), class: "day-pill #{'active' if day == @date}" do %>
      <div class="day-label"><%= day_labels_map[day.wday] %></div>
      <div class="day-number"><%= day.day %></div>
    <% end %>
  <% end %>
<% end %>

<%# --- CONTENU --- %>
<h1 style="font-size: 20px; font-weight: 700; margin: 20px 0 15px;">
  Résultats foot <%= date_label %>
</h1>

<% if @matches.any? %>
  <%
    live_statuses     = %w[1H HT 2H ET BT P]
    finished_statuses = %w[FT AET PEN]
  %>
  <% @matches.each do |match| %>
    <%
      is_live     = live_statuses.include?(match.status)
      is_finished = finished_statuses.include?(match.status)
      has_score   = match.home_score.present? && match.away_score.present?
    %>
    <%= link_to match_path(match.slug || match.id), style: "text-decoration: none; color: inherit; display: block;" do %>
    <div style="padding: 16px 0; border-bottom: 1px solid #f0f0f0;">
      <%# Ligne 1 : Heure + Score + Statut %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <div style="font-weight: 800; font-size: 15px; background: #f4f4f4; padding: 2px 8px; border-radius: 4px;">
            <%= match.start_time.strftime("%H:%M") %>
          </div>
          <% if has_score %>
            <span style="font-weight: 900; font-size: 15px; color: #222;"><%= match.home_score %> - <%= match.away_score %></span>
            <% if is_live %>
              <span class="match-status live" style="font-size: 11px;">
                <%= match.status == "HT" ? "MT" : "#{match.elapsed}′" %>
              </span>
            <% else %>
              <span class="match-status finished" style="font-size: 11px;">Terminé</span>
            <% end %>
          <% end %>
        </div>
        <div style="font-size: 12px; color: #d9534f; font-weight: 700; text-transform: uppercase;">
          <%= match.tv_channels %>
        </div>
      </div>

      <%# Ligne 2 : Équipes %>
      <div style="display: flex; align-items: center; margin-bottom: 6px;">
        <div style="display: flex; align-items: center; flex: 1;">
          <img src="<%= match.home_team_logo %>" alt="Logo <%= match.home_team %>" width="20" height="20" loading="lazy" style="width: 20px; height: 20px; object-fit: contain; margin-right: 10px;">
          <span style="font-size: 16px; font-weight: 600;"><%= match.home_team %></span>
        </div>
        <span style="margin: 0 10px; color: #ccc; font-size: 12px;">vs</span>
        <div style="display: flex; align-items: center; flex: 1; justify-content: flex-end;">
          <span style="font-size: 16px; font-weight: 600; text-align: right;"><%= match.away_team %></span>
          <img src="<%= match.away_team_logo %>" alt="Logo <%= match.away_team %>" width="20" height="20" loading="lazy" style="width: 20px; height: 20px; object-fit: contain; margin-left: 10px;">
        </div>
      </div>

      <%# Ligne 3 : Compétition %>
      <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 0.5px;">
        <%= match.competition %>
      </div>
    </div>
    <% end %>
  <% end %>
<% else %>
  <p style="text-align: center; padding: 40px 0; color: #666;">Aucun résultat disponible pour ce jour.</p>
<% end %>
