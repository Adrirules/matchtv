<% content_for :title, @page_title %>
<% content_for :meta_description, @page_desc %>

<div style="max-width: 860px; margin: 0 auto; padding: 0 16px;">

  <nav style="font-size: 12px; color: #999; margin-bottom: 20px;">
    <%= link_to "Accueil", root_path, style: "color: #999; text-decoration: none;" %> ›
    <span>Chaînes TV foot</span>
  </nav>

  <h1 style="font-size: 24px; font-weight: 800; color: #010e1b; margin: 0 0 8px;">Chaînes TV foot 2025-2026</h1>
  <p style="font-size: 15px; color: #555; margin: 0 0 28px; line-height: 1.6;">Canal+, beIN Sports, DAZN, Amazon Prime... Retrouvez le programme football par diffuseur et tous les prochains matchs sur chaque chaîne.</p>

  <div style="display: flex; flex-direction: column; gap: 10px;">
    <% @channels.each do |ch| %>
      <%= link_to channel_path(ch[:slug]), style: "text-decoration: none; color: inherit;" do %>
        <div style="border: 1px solid #e2e8f0; border-radius: 8px; padding: 18px 20px; background: white; transition: all 0.15s;" onmouseover="this.style.borderColor='#3b82f6';this.style.background='#f8faff'" onmouseout="this.style.borderColor='#e2e8f0';this.style.background='white'">
          <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
            <div>
              <p style="font-weight: 700; font-size: 16px; color: #010e1b; margin: 0 0 4px;"><%= ch[:name] %></p>
              <p style="font-size: 13px; color: #64748b; margin: 0;"><%= ch[:tagline] %></p>
            </div>
            <% if ch[:upcoming_count] > 0 %>
              <span style="background: #f0f7ff; color: #3b82f6; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 9999px; white-space: nowrap; flex-shrink: 0;">
                <%= ch[:upcoming_count] %> match<%= ch[:upcoming_count] > 1 ? 's' : '' %> à venir
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Maillage interne %>
  <div style="margin-top: 36px; padding-top: 24px; border-top: 1px solid #e2e8f0; display: flex; gap: 20px; flex-wrap: wrap;">
    <p style="font-size: 13px; color: #64748b; margin: 0; flex-basis: 100%; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Voir aussi</p>
    <%= link_to "Programme TV du jour", root_path, style: "font-size: 14px; color: #3b82f6; text-decoration: none;" %>
    <%= link_to "Toutes les compétitions", competitions_path, style: "font-size: 14px; color: #3b82f6; text-decoration: none;" %>
    <%= link_to "Guide abonnements foot 2026", blog_article_path("abonnement-foot-2026-quelle-chaine-choisir"), style: "font-size: 14px; color: #3b82f6; text-decoration: none;" %>
  </div>

</div>
