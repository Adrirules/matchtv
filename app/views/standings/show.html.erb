<% content_for :title, @page_title %>
<% content_for :meta_description, @page_desc %>

<%# Fil d'Ariane %>
<nav style="padding: 10px 15px; font-size: 12px; color: #999;">
  <%= link_to "Accueil", root_path, style: "color: #999; text-decoration: none;" %> ›
  <%= link_to "Classements", standings_path, style: "color: #999; text-decoration: none;" %> ›
  <%= @league_name || @league_info[:name] %>
</nav>

<%# Header ligue %>
<div style="text-align: center; padding: 20px 15px; background: white; border-bottom: 1px solid #eee; margin-bottom: 20px;">
  <% if @league_logo.present? %>
    <img src="<%= @league_logo %>" alt="Logo <%= @league_name %>" width="60" height="60" loading="eager"
         style="width: 60px; height: 60px; object-fit: contain; margin-bottom: 10px;">
  <% end %>
  <h1 style="font-size: 22px; font-weight: 800; margin: 0;">Classement <%= @league_name || @league_info[:name] %></h1>
  <p style="color: #666; font-size: 13px; margin-top: 4px;">Saison 2025-2026 · Mis à jour en temps réel</p>
</div>

<div style="padding: 0 10px;">

  <% if @standings.present? %>

    <%# Résumé rapide leader %>
    <% leader = @standings.first %>
    <% if leader %>
      <% leader_name = leader.dig("team", "name") %>
      <% leader_pts  = leader["points"] %>
      <% second_pts  = @standings[1]&.[]("points").to_i %>
      <p style="font-size: 14px; color: #555; line-height: 1.6; margin-bottom: 16px; background: #f9f9f9; padding: 12px 14px; border-radius: 10px;">
        <strong><%= leader_name %></strong> est en tête du classement avec <strong><%= leader_pts %> points</strong><% if leader_pts - second_pts > 0 %>, soit <strong><%= leader_pts - second_pts %> point<%= 's' if leader_pts - second_pts > 1 %> d'avance</strong> sur le deuxième<% end %>.
        <% total_played = leader.dig("all", "played").to_i %>
        <% if total_played > 0 %> <%= total_played %> journée<%= 's' if total_played > 1 %> ont été disputées cette saison.<% end %>
      </p>
    <% end %>

    <%# Légende zones %>
    <%
      zones = case params[:competition_id]
      when "ligue-1"
        { cl: (1..2), cl_q: (3..3), el: (4..4), conf: (5..5), releg_barrage: (16..16), releg: (17..18) }
      when "ligue-2"
        { promo: (1..2), promo_barrage: (3..4), releg_barrage: (15..16), releg: (17..18) }
      when "premier-league"
        { cl: (1..4), el: (5..5), conf: (6..6), releg: (18..20) }
      when "la-liga"
        { cl: (1..4), el: (5..5), conf: (6..6), releg: (18..20) }
      when "bundesliga"
        { cl: (1..4), el: (5..5), conf: (6..6), releg_barrage: (16..16), releg: (17..18) }
      when "serie-a"
        { cl: (1..4), el: (5..5), conf: (6..6), releg: (18..20) }
      when "national"
        { promo: (1..1), promo_barrage: (2..3), releg: (14..15) }
      else
        {}
      end

    %>

    <%# Tableau classement %>
    <div style="overflow-x: auto; margin-bottom: 20px;">
      <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); font-size: 13px;">
        <thead>
          <tr style="background: #f8f9fa; font-size: 11px; color: #888; font-weight: 700; text-transform: uppercase;">
            <th style="padding: 10px 8px; text-align: center; width: 28px;">#</th>
            <th style="padding: 10px 8px; text-align: left;">Équipe</th>
            <th style="padding: 10px 8px; text-align: center;">J</th>
            <th style="padding: 10px 8px; text-align: center;">V</th>
            <th style="padding: 10px 8px; text-align: center;">N</th>
            <th style="padding: 10px 8px; text-align: center;">D</th>
            <th style="padding: 10px 8px; text-align: center;">BP</th>
            <th style="padding: 10px 8px; text-align: center;">BC</th>
            <th style="padding: 10px 8px; text-align: center;">Diff</th>
            <th style="padding: 10px 8px; text-align: center; font-weight: 900; color: #010e1b;">Pts</th>
            <th style="padding: 10px 8px; text-align: center;">Forme</th>
          </tr>
        </thead>
        <tbody>
          <% @standings.each_with_index do |rank, i| %>
            <% team_slug = rank.dig("team", "name")&.parameterize %>
            <% zone_col = zone_color(rank["rank"], zones) %>
            <tr style="border-bottom: 1px solid #f0f0f0; <%= i.even? ? '' : 'background: #fafafa;' %>">
              <td style="padding: 10px 6px; text-align: center;">
                <div style="display: flex; align-items: center; gap: 3px;">
                  <% if zone_col %>
                    <span style="display: inline-block; width: 3px; height: 18px; border-radius: 2px; background: <%= zone_col %>; margin-right: 4px;"></span>
                  <% end %>
                  <span style="font-weight: 700; font-size: 12px; color: #666;"><%= rank["rank"] %></span>
                </div>
              </td>
              <td style="padding: 10px 8px;">
                <%= link_to team_path(team_slug), style: "text-decoration: none; color: inherit; display: flex; align-items: center; gap: 8px;" do %>
                  <img src="<%= rank.dig("team", "logo") %>" alt="<%= rank.dig("team", "name") %>"
                       width="20" height="20" loading="lazy"
                       style="width: 20px; height: 20px; object-fit: contain; flex-shrink: 0;">
                  <span style="font-weight: 600; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 110px;"><%= rank.dig("team", "name") %></span>
                <% end %>
              </td>
              <td style="padding: 10px 6px; text-align: center; color: #666;"><%= rank.dig("all", "played") %></td>
              <td style="padding: 10px 6px; text-align: center; color: #28a745;"><%= rank.dig("all", "win") %></td>
              <td style="padding: 10px 6px; text-align: center; color: #888;"><%= rank.dig("all", "draw") %></td>
              <td style="padding: 10px 6px; text-align: center; color: #dc3545;"><%= rank.dig("all", "lose") %></td>
              <td style="padding: 10px 6px; text-align: center; color: #555;"><%= rank.dig("goals", "for") %></td>
              <td style="padding: 10px 6px; text-align: center; color: #555;"><%= rank.dig("goals", "against") %></td>
              <td style="padding: 10px 6px; text-align: center; color: <%= rank["goalsDiff"].to_i >= 0 ? '#28a745' : '#dc3545' %>; font-weight: 600;">
                <%= rank["goalsDiff"].to_i > 0 ? "+#{rank["goalsDiff"]}" : rank["goalsDiff"] %>
              </td>
              <td style="padding: 10px 6px; text-align: center; font-weight: 900; font-size: 15px; color: #010e1b;"><%= rank["points"] %></td>
              <td style="padding: 10px 6px; text-align: center;">
                <% form = rank["form"] || "" %>
                <div style="display: flex; gap: 2px; justify-content: center;">
                  <% form.last(5).each_char do |r| %>
                    <% bg = r == 'W' ? '#28a745' : (r == 'D' ? '#aaa' : '#dc3545') %>
                    <span style="background: <%= bg %>; width: 14px; height: 14px; border-radius: 3px; display: inline-block;" title="<%= r == 'W' ? 'Victoire' : (r == 'D' ? 'Nul' : 'Défaite') %>"></span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Légende %>
    <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 24px; font-size: 11px; color: #666;">
      <% if zones[:cl] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #1a56db; display: inline-block;"></span> Champions League
        </span>
      <% end %>
      <% if zones[:el] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #f97316; display: inline-block;"></span> Europa League
        </span>
      <% end %>
      <% if zones[:conf] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #10b981; display: inline-block;"></span> Conference League
        </span>
      <% end %>
      <% if zones[:promo] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #22c55e; display: inline-block;"></span> Montée directe
        </span>
      <% end %>
      <% if zones[:promo_barrage] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #84cc16; display: inline-block;"></span> Barrage montée
        </span>
      <% end %>
      <% if zones[:releg_barrage] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #f59e0b; display: inline-block;"></span> Barrage relégation
        </span>
      <% end %>
      <% if zones[:releg] %>
        <span style="display: flex; align-items: center; gap: 4px;">
          <span style="width: 10px; height: 10px; border-radius: 2px; background: #ef4444; display: inline-block;"></span> Relégation
        </span>
      <% end %>
    </div>

  <% else %>
    <p style="text-align: center; color: #666; padding: 40px 0;">Classement non disponible pour le moment.</p>
  <% end %>

  <%= render 'shared/ad_unit', slot_id: '1499436694' %>

  <%# Lien vers autres classements %>
  <div style="margin-top: 8px;">
    <h2 style="font-size: 14px; font-weight: 700; color: #010e1b; margin-bottom: 10px;">Autres classements</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      <% StandingsController::LEAGUES.reject { |l| l[:slug] == params[:competition_id] }.first(6).each do |l| %>
        <%= link_to standing_path(l[:slug]),
            style: "background: #f4f4f4; border-radius: 8px; padding: 6px 12px; font-size: 13px; font-weight: 600; color: #333; text-decoration: none;" do %>
          <%= l[:name] %>
        <% end %>
      <% end %>
    </div>
  </div>

</div>

<%# JSON-LD %>
<script type="application/ld+json">
<%= {
  "@context" => "https://schema.org",
  "@type" => "BreadcrumbList",
  "itemListElement" => [
    { "@type" => "ListItem", "position" => 1, "name" => "Accueil", "item" => "https://www.coupdenvoi.tv/" },
    { "@type" => "ListItem", "position" => 2, "name" => "Classements", "item" => "https://www.coupdenvoi.tv/classements" },
    { "@type" => "ListItem", "position" => 3, "name" => @league_name || @league_info[:name], "item" => request.original_url }
  ]
}.to_json.html_safe %>
</script>
