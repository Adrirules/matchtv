<% content_for :title, @page_title %>
<% content_for :meta_description, @page_desc %>

<div style="padding: 0 15px;">

  <%# Breadcrumb %>
  <div style="font-size: 12px; color: #94a3b8; margin: 8px 0 16px; display: flex; align-items: center; gap: 6px;">
    <%= link_to "Compétitions", competitions_path, style: "color: #94a3b8; text-decoration: none;" %>
    <span>›</span>
    <%= link_to "Coupe du Monde 2026", competition_path("coupe-du-monde-2026"), style: "color: #94a3b8; text-decoration: none;" %>
    <span>›</span>
    <span style="color: #010e1b; font-weight: 600;">Meilleurs buteurs</span>
  </div>

  <%# Header %>
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
    <img src="<%= FootballApiService.league_logo(1) %>" alt="Coupe du Monde 2026"
         width="40" height="40" style="width: 40px; height: 40px; object-fit: contain;">
    <div>
      <h1 style="font-size: 20px; font-weight: 800; color: #010e1b; margin: 0; font-family: var(--font-heading);">
        Meilleurs buteurs — Coupe du Monde 2026
      </h1>
      <p style="font-size: 13px; color: #64748b; margin: 2px 0 0;">
        Classement mis à jour en temps réel · Soulier d'Or FIFA 2026
      </p>
    </div>
  </div>

  <% if !@tournament_started %>
    <%# Avant le tournoi : teaser avec les favoris %>
    <div style="background: white; border-radius: 12px; border: 1px solid #e2e8f0; padding: 20px; margin-bottom: 20px;">
      <p style="font-size: 15px; font-weight: 700; color: #010e1b; margin: 0 0 8px;">
        Le tournoi commence le 11 juin 2026
      </p>
      <p style="font-size: 14px; color: #64748b; margin: 0; line-height: 1.6;">
        Le classement des buteurs sera disponible en temps réel dès le coup d'envoi du premier match.
        Kylian Mbappé, Erling Haaland, Vinicius Jr., Jude Bellingham... Qui décrochera le Soulier d'Or ?
      </p>
    </div>

    <%# Favoris au Golden Boot %>
    <h2 style="font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; margin: 0 0 8px;">
      Les favoris au Soulier d'Or
    </h2>
    <div style="background: white; border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; margin-bottom: 20px;">
      <% [
        { name: "Kylian Mbappé", country: "France", team: "Real Madrid", group: "I" },
        { name: "Erling Haaland", country: "Norvège", team: "Manchester City", group: "I" },
        { name: "Vinicius Jr.", country: "Brésil", team: "Real Madrid", group: "C" },
        { name: "Jude Bellingham", country: "Angleterre", team: "Real Madrid", group: "L" },
        { name: "Lamine Yamal", country: "Espagne", team: "FC Barcelone", group: "H" },
        { name: "Lionel Messi", country: "Argentine", team: "Inter Miami", group: "J" },
      ].each_with_index do |player, i| %>
        <div style="display: flex; align-items: center; gap: 12px; padding: 12px 14px; <%= i < 5 ? 'border-bottom: 1px solid #f1f5f9;' : '' %>">
          <span style="width: 24px; font-size: 14px; font-weight: 800; color: #94a3b8; text-align: center;"><%= i + 1 %></span>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 14px; font-weight: 700; color: #010e1b;"><%= player[:name] %></div>
            <div style="font-size: 12px; color: #64748b;"><%= player[:country] %> · <%= player[:team] %></div>
          </div>
          <%= link_to world_cup_group_path(letter: player[:group].downcase),
              style: "font-size: 11px; font-weight: 700; background: #f1f5f9; color: #64748b; padding: 3px 8px; border-radius: 6px; text-decoration: none;" do %>
            Groupe <%= player[:group] %>
          <% end %>
        </div>
      <% end %>
    </div>

  <% elsif @scorers.any? %>
    <%# Pendant le tournoi : classement live %>
    <div style="background: white; border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; margin-bottom: 20px;">
      <div style="display: flex; align-items: center; padding: 8px 14px; border-bottom: 1px solid #f1f5f9; background: #f8fafc;">
        <span style="width: 28px; font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase;">#</span>
        <span style="flex: 1; font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; margin-left: 42px;">Joueur</span>
        <span style="width: 36px; font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; text-align: center;">Buts</span>
        <span style="width: 36px; font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; text-align: center;">Pds</span>
      </div>
      <% @scorers.first(20).each_with_index do |entry, i| %>
        <% player = entry["player"] %>
        <% stats = entry.dig("statistics", 0) %>
        <% player_slug = player["name"]&.parameterize %>
        <%= link_to player_path(player_slug), style: "display: flex; align-items: center; gap: 12px; padding: 10px 14px; text-decoration: none; color: inherit; border-bottom: 1px solid #f1f5f9;" do %>
          <span style="width: 28px; font-size: 13px; font-weight: 800; color: #94a3b8; text-align: center;"><%= i + 1 %></span>
          <img src="<%= player["photo"] %>" alt="<%= player["name"] %>"
               width="30" height="30" loading="lazy"
               style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover; flex-shrink: 0;">
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 14px; font-weight: 700; color: #010e1b; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <%= player["name"] %>
            </div>
            <div style="font-size: 12px; color: #64748b;">
              <%= stats&.dig("team", "name") %>
            </div>
          </div>
          <span style="width: 36px; font-size: 16px; font-weight: 900; color: #010e1b; text-align: center; font-family: var(--font-heading);">
            <%= stats&.dig("goals", "total") || 0 %>
          </span>
          <span style="width: 36px; font-size: 13px; font-weight: 600; color: #64748b; text-align: center;">
            <%= stats&.dig("goals", "assists") || 0 %>
          </span>
        <% end %>
      <% end %>
    </div>

  <% else %>
    <div style="background: white; border-radius: 12px; border: 1px solid #e2e8f0; padding: 20px; text-align: center;">
      <p style="font-size: 14px; color: #64748b; margin: 0;">Aucun but marqué pour l'instant.</p>
    </div>
  <% end %>

  <div style="margin-top: 8px;">
    <%= link_to competition_path("coupe-du-monde-2026"), style: "font-size: 13px; color: var(--color-accent); font-weight: 700; text-decoration: none;" do %>
      ← Retour Coupe du Monde 2026
    <% end %>
  </div>

</div>
